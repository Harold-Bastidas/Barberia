# ============================================================
# Infraestructura — Docker Compose
# Copiar a .env en la raíz: cp .env.example .env
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────

# Usuario administrador de la base de datos
POSTGRES_USER=barber_user

# Contraseña del usuario postgres (cambiar en producción)
POSTGRES_PASSWORD=changeme_dev_only

# Nombre de la base de datos principal de la aplicación
POSTGRES_DB=barberia

# Puerto expuesto en el host. Se usa 5433 para no colisionar con un
# Postgres local que ya corra en el puerto por defecto (5432).
POSTGRES_PORT=5433

# ─── n8n (Orquestador de workflows) ──────────────────────────────────────────

# Puerto expuesto en el host para el dashboard de n8n
N8N_PORT=5678

# Clave de encriptación para las credenciales guardadas en n8n.
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_32_hex_chars_generated_by_openssl

# Usuario y contraseña para acceder al dashboard de n8n (autenticación básica)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n

# ─── Evolution API (Gateway WhatsApp) ────────────────────────────────────────

# Puerto expuesto en el host para la API de Evolution
EVOLUTION_PORT=8080

# API key que usará el backend para autenticar peticiones al gateway.
# Generar con: openssl rand -hex 32
EVOLUTION_API_KEY=replace_with_api_key_generated_by_openssl

# ─── Adminer (Inspector visual de la DB — solo desarrollo) ───────────────────

# Puerto expuesto en el host para Adminer
ADMINER_PORT=8081

    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "fastify": "^4.28.0",
    "jose": "^5.9.4",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",

# ============================================================
# Backend — API Fastify
# Copiar a backend/.env: cp backend/.env.example backend/.env
# ============================================================

# ─── Entorno ─────────────────────────────────────────────────────────────────

# Modo de ejecución. Valores: development | test | production
NODE_ENV=development

# Puerto en que escucha el servidor HTTP
PORT=3001

# Nivel de detalle de los logs (pino). Valores: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Base de datos ────────────────────────────────────────────────────────────

# URL de conexión a PostgreSQL (Prisma connection string).
# En Docker Compose: el host es "localhost" con el POSTGRES_PORT del .env raíz.
# En producción: cambiar host, puerto y contraseña.
DATABASE_URL=postgresql://barber_user:changeme_dev_only@localhost:5433/barberia?schema=public

# ─── JWT — RS256 ─────────────────────────────────────────────────────────────

# Ruta al archivo PEM de la clave privada RSA (4096 bits).
# Generar: openssl genrsa -out certs/private.pem 4096
JWT_PRIVATE_KEY_PATH=./certs/private.pem

# Ruta al archivo PEM de la clave pública RSA.
# Generar: openssl rsa -in certs/private.pem -pubout -out certs/public.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem

# Tiempo de expiración del access token (formato jose: "15m", "1h", etc.)
JWT_EXPIRES_IN=15m

# ─── Refresh tokens ──────────────────────────────────────────────────────────

# Secreto para firmar los refresh tokens (HMAC).
# Generar: openssl rand -hex 64
REFRESH_TOKEN_SECRET=replace_with_128_char_hex_generated_by_openssl

# Duración de los refresh tokens en días
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── CORS ────────────────────────────────────────────────────────────────────

# Orígenes permitidos separados por coma (sin espacios).
# En producción: solo el dominio real (https://barberia.example.com).
CORS_ORIGINS=http://localhost:3000

# ─── Integración con n8n ─────────────────────────────────────────────────────

# URL base de los webhooks de n8n. El backend envía eventos (nueva reserva,
# cancelación, etc.) a n8n para que dispare las notificaciones WhatsApp.
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

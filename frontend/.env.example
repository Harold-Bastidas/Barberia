# ============================================================
# Frontend — Next.js 14
# Copiar a frontend/.env.local: cp frontend/.env.example frontend/.env.local
#
# Las variables NEXT_PUBLIC_* quedan expuestas en el bundle del cliente
# (navegador). No incluir secretos en variables NEXT_PUBLIC_*.
# ============================================================

# URL del API REST del backend. Usada tanto en Server Components (SSR)
# como en Client Components (fetch del navegador).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL pública de la propia aplicación frontend. Sirve para construir
# URLs absolutas en emails, webhooks, og:url, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
